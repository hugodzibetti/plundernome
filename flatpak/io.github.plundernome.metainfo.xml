<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.plundernome</id>
  <name>Plundernome</name>
  <summary>Game repack browser and downloader for Linux</summary>
  <developer id="io.github.plundernome">
    <name>Plundernome Contributors</name>
  </developer>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>Plundernome is a desktop application for browsing, downloading, and managing games from multiple repack sources.</p>
    <p>Features include catalog browsing with search and filters, download queue management, Wine/Proton compatibility detection, and automatic dependency installation.</p>
  </description>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <categories>
    <category>Game</category>
  </categories>
  <url type="homepage">https://github.com/anomalyco/plundernome</url>
  <url type="bugtracker">https://github.com/anomalyco/plundernome/issues</url>
  <url type="donation">https://github.com/sponsors/anomalyco</url>
  <content_rating type="oars-3.1">
