{
  "id": "gload",
  "name": "GLOAD.to",
  "baseUrl": "https://gload.to",
  "mirrors": [],
  "scrapeType": "html",
  "selectors": {
    "gameContainer": "article.game-archive-card",
    "title": "h2.card-title, h3.list-title",
    "link": "a.card-link-wrapper",
    "size": ".card-size",
    "description": ".card-excerpt",
    "image": "picture img",
    "date": ".card-date",
    "tags": ".card-genre"
  },
  "downloadLinkSelector": "a[href*='magnet:'], a[href*='torrent'], a[href*='upload'], a[href*='mega']",
  "downloadLinkType": "direct",
  "downloadLinkContainer": ".entry-content",
  "downloadType": "direct",
  "updateIntervalMinutes": 360,
  "enabled": true
}