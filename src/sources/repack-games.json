{
  "id": "repack-games",
  "name": "Repack Games",
  "baseUrl": "https://repack-games.com",
  "mirrors": [],
  "scrapeType": "html",
  "selectors": {
    "gameContainer": "article",
    "title": "h2 a",
    "link": "h2 a",
    "size": "span.size, .post-meta",
    "description": "p",
    "image": "img",
    "date": "time, span.date",
    "tags": "a[rel=tag], .genre a"
  },
  "downloadLinkSelector": "a[href*='torrent'], a[href*='magnet:'], a[href*='.zip'], a[href*='download']",
  "downloadLinkType": "direct",
  "downloadLinkContainer": ".entry-content, .download-links",
  "downloadType": "direct",
  "updateIntervalMinutes": 360,
  "enabled": true
}